{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/:path((?!api/|.*\\.).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/chat.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/nudge", "schedule": "0 9 * * *" }
  ]
}
