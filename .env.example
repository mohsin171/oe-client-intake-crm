# Copy to .env for local development. On Vercel, set these in Project Settings.

# The AI key. Without it, the tool runs in DEMO MODE (canned replies).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Postgres connection string. On Vercel, adding a Postgres store injects this
# automatically. Locally, point it at your local Postgres.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Resend key for sending team-alert emails (optional; logs to console if unset).
RESEND_API_KEY=re_your_key_here
